rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Storefront catalogue — public read, signed-in (admin) write.
    match /categories/{id} {
      allow read:  if true;
      allow write: if request.auth != null;
    }
    match /subcategories/{id} {
      allow read:  if true;
      allow write: if request.auth != null;
    }
    match /products/{id} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // Generation jobs — only signed-in users (admin or backend SA).
    match /generationJobs/{id} {
      allow read, write: if request.auth != null;
    }
  }
}

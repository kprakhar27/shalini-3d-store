# Firebase Admin SDK (Firestore + Auth only — no Storage)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Cloudflare R2 storage (10 GB free, no billing required)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=shalini-3d-store
# Public dev URL of the bucket — set this after enabling "R2.dev subdomain" in the bucket settings.
# Looks like: https://pub-<hash>.r2.dev
R2_PUBLIC_URL=

# Hugging Face — image-to-3D via public Spaces. Both are optional.
# HF_3D_SPACE accepts a *comma-separated list* of image-to-3D Spaces. The
# backend auto-detects the API of each Space (Hunyuan3D-2, TRELLIS, or TripoSR)
# and falls through to the next one if a Space is sleeping / 503. The default
# below puts Hunyuan3D-2 first because it has the simplest single-call API and
# does its own background removal — typically the most reliable from outside.
# the backend tries them in order and uses the first one that connects, so a
# single broken Space (RUNTIME_ERROR / sleeping) won't block generation.
HF_TOKEN=
HF_3D_SPACE=tencent/Hunyuan3D-2,microsoft/TRELLIS,stabilityai/TripoSR

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,https://your-storefront.vercel.app
